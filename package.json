{
    "name": "bcrhp",
    "version": "1.4.1",
    "license": "AGPL-3.0-only",
    "scripts": {
        "build_development": "npm run eslint:check && cross-env webpack --config ./webpack/webpack.config.dev.js",
        "build_production": "npm run eslint:check && npm run ts:check && cross-env webpack --config ./webpack/webpack.config.prod.js",
        "build_test": "npm run eslint:check && npm run ts:check && cross-env webpack --config ./webpack/webpack.config.dev.js --env test=true",
        "eslint:check": "eslint **/src",
        "eslint:fix": "eslint --fix",
        "eslint:fix:all": "npm run eslint:fix **/src",
        "eslint:watch": "nodemon --watch . --ext ts,vue --exec npm run --silent eslint:check",
        "gettext:compile": "vue-gettext-compile",
        "gettext:extract": "vue-gettext-extract",
        "prettier:check": "prettier bcrhp/src --check",
        "prettier:fix": "prettier --write",
        "prettier:fix:all": "npm run prettier:fix **/src",
        "start": "cross-env webpack serve --config ./webpack/webpack.config.dev.js",
        "ts:check": "vue-tsc --noEmit",
        "ts:watch": "vue-tsc --watch --noEmit",
        "vite_build": "DEBUG=vite:*  vite build",
        "vite_dev": "DEBUG=vite:* vite  --host --force",
        "vitest": "vitest --run --coverage"
    },
    "overrides": {
        "geojson": "0.5.0",
        "js-cookie": "3.0.7",
        "moment-timezone": "^0.5.45",
        "nomnom": "npm:@gerhobbelt/nomnom",
        "rimraf": "^5.0.7",
        "underscore": "^1.13.6"
    },
    "dependencies": {
        "@ckeditor/ckeditor5-vue": "7.3.0",
        "@primeuix/themes": "^1.1.1",
        "@primevue/forms": "^4.3.5",
        "@vitejs/plugin-vue": "^5.2.4",
        "arches": "github:bcgov/arches#v8.0.10-bcgov",
        "arches-component-lab": "github:bcgov/arches-component-lab#v0.0.1a13-bcgov",
        "arches-querysets": "github:bcgov/arches-querysets#v1.1.1-bcgov",
        "bcgov_arches_common": "github:bcgov/bcgov-arches-common#v2.0.1",
        "ckeditor5": "44.2.0",
        "dayjs": "^1.11.13",
        "dompurify": "^3.3.0",
        "maplibre-gl": "^5.10.0",
        "playwright": "^1.58.0",
        "primevue": "^4.3.4",
        "quill": "^2.0.3",
        "vite": "^6.4.3",
        "vue": "^3.5.16",
        "vue-router": "^4.5.1",
        "zod": "^4.1.5"
    },
    "devDependencies": {
        "@eslint/js": "^9.20.0",
        "@html-eslint/eslint-plugin": "^0.41.0",
        "@html-eslint/parser": "^0.41.0",
        "@playwright/test": "^1.58.0",
        "@primevue/auto-import-resolver": "^4.3.1",
        "@types/geojson": "^7946.0.16",
        "@types/uuid": "^10.0.0",
        "@typescript-eslint/parser": "^8.24.1",
        "@vue/eslint-config-prettier": "^10.2.0",
        "@vue/eslint-config-typescript": "^14.4.0",
        "arches-dev-dependencies": "archesproject/arches-dev-dependencies#stable/8.0.10",
        "dotenv": "^17.3.1",
        "eslint": "^9.29.0",
        "eslint-plugin-vue": "^9.32.0",
        "globals": "^16.0.0",
        "lightningcss": "^1.29.2",
        "prettier": "^3.5.1",
        "prettier-eslint": "^16.3.0",
        "typescript": "^5.6.2",
        "typescript-eslint": "^8.24.1",
        "unplugin-vue-components": "^28.4.1",
        "vite-plugin-css-injected-by-js": "^3.5.2",
        "vite-plugin-node-polyfills": "^0.23.0",
        "vue-eslint-parser": "^9.4.3"
    },
    "nodeModulesPaths": {}
}
